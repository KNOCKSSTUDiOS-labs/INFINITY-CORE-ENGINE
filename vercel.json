vercel.json name
{
  "version": 2,
  "name": "infinity-core-engine",
  "alias": [
    "infinitycore.studio",
    "hollywoodimaging.studio"
  ],
  "env": {
    "VITE_API_KEY": {
      "required": true
    },
    "VITE_STRIPE_KEY": {
      "required": true
    },
    "VITE_AI_ENDPOINT": {
      "required": true
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
